# Server Environment Variables
# Copy this file to .env and fill in your values

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/society_maintenance_tracker
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Overdue detection thresholds (days open before flagged overdue)
OVERDUE_DAYS_HIGH=2
OVERDUE_DAYS_MEDIUM=5
OVERDUE_DAYS_LOW=7
OVERDUE_CHECK_INTERVAL_MS=3600000

# Email notifications (optional - use Gmail, SendGrid, or Ethereal for testing)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="Society Tracker <noreply@society.local>"
